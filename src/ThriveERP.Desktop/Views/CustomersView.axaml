<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ThriveERP.Desktop.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ThriveERP.Desktop.Views.CustomersView"
             x:DataType="vm:CustomersViewModel">
  <Panel>
    <DockPanel Margin="20">
      <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,20">
        <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
        <Button Content="Refresh" Command="{Binding LoadCustomersCommand}" Margin="20,0,0,0" VerticalAlignment="Center"/>
        <Button Content="Add Customer" Command="{Binding ShowAddCustomerCommand}" Background="#107C10" Foreground="White" Margin="10,0,0,0" VerticalAlignment="Center"/>
      </StackPanel>

      <DataGrid ItemsSource="{Binding Customers}" 
                AutoGenerateColumns="False" 
                IsReadOnly="True"
                GridLinesVisibility="All"
                BorderThickness="1"
                BorderBrush="Gray">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
          <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="150" />
          <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150" />
          <DataGridTextColumn Header="Balance" Binding="{Binding CurrentBalance, StringFormat={}{0:C}}" Width="100" />
          <DataGridTemplateColumn Header="Actions" Width="150">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <StackPanel Orientation="Horizontal" Spacing="5" Margin="5">
                  <Button Content="Edit" Command="{Binding $parent[UserControl].((vm:CustomersViewModel)DataContext).EditCustomerCommand}" CommandParameter="{Binding}" Background="#3B82F6" Foreground="White" Padding="10,5"/>
                  <Button Content="Delete" Command="{Binding $parent[UserControl].((vm:CustomersViewModel)DataContext).DeleteCustomerCommand}" CommandParameter="{Binding}" Background="#EF4444" Foreground="White" Padding="10,5"/>
                </StackPanel>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
        </DataGrid.Columns>
      </DataGrid>
    </DockPanel>

    <!-- Overlay -->
    <Border Background="#80000000" IsVisible="{Binding CurrentOverlay, Converter={x:Static ObjectConverters.IsNotNull}}">
      <ContentControl Content="{Binding CurrentOverlay}" />
    </Border>
  </Panel>
</UserControl>
