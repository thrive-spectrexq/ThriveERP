<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ThriveERP.Desktop.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ThriveERP.Desktop.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">
    
    <Grid RowDefinitions="Auto, *">
        <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="Bold" Margin="20" />
        <Border Grid.Row="1" Background="#f3f4f6" CornerRadius="8" Margin="20,0,20,20" Padding="20">
            <TextBlock Text="{Binding WelcomeMessage}" FontSize="16" />
        </Border>
    </Grid>
</UserControl>
