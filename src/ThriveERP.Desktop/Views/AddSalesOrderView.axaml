<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ThriveERP.Desktop.ViewModels"
             x:Class="ThriveERP.Desktop.Views.AddSalesOrderView"
             x:DataType="vm:AddSalesOrderViewModel">
  <Grid>
    <Border Padding="20" Background="{DynamicResource SystemRegionBrush}" 
          BorderBrush="Gray" BorderThickness="1" CornerRadius="8"
          HorizontalAlignment="Center" VerticalAlignment="Center" Width="800" MaxHeight="600">
    <Grid RowDefinitions="Auto, *, Auto">
      <StackPanel Grid.Row="0" Margin="0,0,0,10" Spacing="10">
        <TextBlock Text="Create Sales Order" FontSize="20" FontWeight="Bold" />
        <StackPanel Orientation="Horizontal" Spacing="10">
          <TextBlock Text="Customer:" VerticalAlignment="Center" FontWeight="SemiBold"/>
          <ComboBox ItemsSource="{Binding AvailableCustomers}" 
                    SelectedItem="{Binding SelectedCustomer}"
                    DisplayMemberBinding="{Binding Name}" 
                    PlaceholderText="Select Customer (Optional)" Width="300"/>
        </StackPanel>
      </StackPanel>
      
      <Grid Grid.Row="1" RowDefinitions="Auto,*">
         <Button Grid.Row="0" Content="Add Item" Command="{Binding AddItemCommand}" Background="#0D9488" Foreground="White" Margin="0,0,0,10" HorizontalAlignment="Left" Padding="10,5" CornerRadius="4"/>
         <DataGrid Grid.Row="1" ItemsSource="{Binding Items}" AutoGenerateColumns="False" IsReadOnly="False">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Product" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding $parent[UserControl].((vm:AddSalesOrderViewModel)DataContext).AvailableProducts}" 
                                      SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
                                      DisplayMemberBinding="{Binding Name}" HorizontalAlignment="Stretch" Margin="5"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="80"/>
                <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice}" Width="100"/>
                <DataGridTextColumn Header="Discount" Binding="{Binding DiscountAmount}" Width="100"/>
                <DataGridTextColumn Header="Line Total" Binding="{Binding LineTotal}" Width="100" IsReadOnly="True"/>
                <DataGridTemplateColumn Header="Actions" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Remove" Command="{Binding $parent[UserControl].((vm:AddSalesOrderViewModel)DataContext).RemoveItemCommand}" CommandParameter="{Binding}" Background="#EF4444" Foreground="White" Margin="5" Padding="5,2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
         </DataGrid>
      </Grid>

      <Grid Grid.Row="2" ColumnDefinitions="*, Auto" Margin="0,20,0,0">
          <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="10" MinWidth="200">
              <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0" Text="Subtotal:" FontWeight="SemiBold" Margin="0,0,10,0"/>
                  <TextBlock Grid.Column="1" Text="{Binding Subtotal, StringFormat={}{0:C}}" />
              </Grid>
              <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0" Text="Tax:" FontWeight="SemiBold" Margin="0,0,10,0"/>
                  <TextBlock Grid.Column="1" Text="{Binding TaxTotal, StringFormat={}{0:C}}" />
              </Grid>
              <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0" Text="Grand Total:" FontWeight="Bold" FontSize="16" Margin="0,0,10,0"/>
                  <TextBlock Grid.Column="1" Text="{Binding GrandTotal, StringFormat={}{0:C}}" FontWeight="Bold" FontSize="16" Foreground="#107C10"/>
              </Grid>

              <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,20,0,0">
                <Button Content="Cancel" Command="{Binding CancelCommand}" />
                <Button Content="Pay Now" Command="{Binding PayNowCommand}" Background="#0078D7" Foreground="White" />
              </StackPanel>
          </StackPanel>
      </Grid>
    </Grid>
  </Border>

  <!-- Payment Overlay -->
  <Grid Background="#80000000" IsVisible="{Binding ShowPaymentOverlay}" ZIndex="100">
      <Border Background="{DynamicResource SystemRegionBrush}" 
              BorderBrush="Gray" BorderThickness="1" CornerRadius="8"
              HorizontalAlignment="Center" VerticalAlignment="Center" 
              Width="400" Padding="30">
          <StackPanel Spacing="15">
              <TextBlock Text="Complete Payment" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
              
              <TextBlock Text="{Binding GrandTotal, StringFormat='Total Due: {0:C}'}" FontSize="24" FontWeight="Bold" Foreground="#107C10" HorizontalAlignment="Center"/>

              <StackPanel Spacing="5">
                  <TextBlock Text="Payment Method:" FontWeight="SemiBold"/>
                  <ComboBox ItemsSource="{Binding AvailablePaymentMethods}" 
                            SelectedItem="{Binding SelectedPaymentMethod}" 
                            HorizontalAlignment="Stretch"/>
              </StackPanel>

              <StackPanel Spacing="5" IsVisible="{Binding SelectedPaymentMethod, Converter={x:Static ObjectConverters.Equal}, ConverterParameter='Cash'}">
                  <TextBlock Text="Amount Tendered:" FontWeight="SemiBold"/>
                  <NumericUpDown Value="{Binding AmountTendered}" Minimum="0" Increment="1" FormatString="C"/>
              </StackPanel>

              <StackPanel Spacing="5" IsVisible="{Binding SelectedPaymentMethod, Converter={x:Static ObjectConverters.Equal}, ConverterParameter='Cash'}">
                  <TextBlock Text="Change / Balance:" FontWeight="SemiBold"/>
                  <TextBlock Text="{Binding ChangeAmount, StringFormat={}{0:C}}" FontSize="20" FontWeight="Bold" Foreground="#EF4444"/>
              </StackPanel>

              <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,20,0,0">
                  <Button Content="Cancel" Command="{Binding CancelPaymentCommand}"/>
                  <Button Content="Confirm &amp; Print Receipt" Command="{Binding ConfirmPaymentCommand}" Background="#0D9488" Foreground="White" FontWeight="Bold"/>
              </StackPanel>
          </StackPanel>
      </Border>
  </Grid>
</Grid>
</UserControl>
