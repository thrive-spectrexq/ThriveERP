<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ThriveERP.Desktop.ViewModels"
             x:Class="ThriveERP.Desktop.Views.AddPurchaseOrderView"
             x:DataType="vm:AddPurchaseOrderViewModel"
             Width="700" Height="500" Background="{DynamicResource SurfaceBrush}" CornerRadius="8">
  <DockPanel Margin="20" Name="RootGrid">
    <TextBlock DockPanel.Dock="Top" Text="New Purchase Order" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
    
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" Margin="0,20,0,0">
      <Button Content="Cancel" Command="{Binding CancelCommand}" Background="#E5E7EB" Foreground="Black" Padding="15,8" CornerRadius="4"/>
      <Button Content="Create Order" Command="{Binding SaveCommand}" Background="#10B981" Foreground="White" Padding="15,8" CornerRadius="4"/>
    </StackPanel>

    <Grid RowDefinitions="Auto,*" ColumnDefinitions="*,*">
      <!-- Order details -->
      <StackPanel Grid.Column="0" Spacing="10" Margin="0,0,10,0">
        <TextBlock Text="Supplier:" FontWeight="SemiBold"/>
        <ComboBox ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier}" HorizontalAlignment="Stretch">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Name}"/>
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>

        <TextBlock Text="Warehouse:" FontWeight="SemiBold" Margin="0,10,0,0"/>
        <ComboBox ItemsSource="{Binding Warehouses}" SelectedItem="{Binding SelectedWarehouse}" HorizontalAlignment="Stretch">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Name}"/>
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
      </StackPanel>

      <!-- Add line items -->
      <StackPanel Grid.Column="1" Spacing="10" Margin="10,0,0,0">
        <TextBlock Text="Add Line Item:" FontWeight="SemiBold"/>
        <ComboBox ItemsSource="{Binding AvailableProducts}" SelectedItem="{Binding SelectedProduct}" HorizontalAlignment="Stretch" PlaceholderText="Select Product">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Name}"/>
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
        
        <Grid ColumnDefinitions="*,*">
          <StackPanel Grid.Column="0" Margin="0,0,5,0">
            <TextBlock Text="Qty:" FontSize="12"/>
            <NumericUpDown Value="{Binding QuantityToAdd}" FormatString="0.00" Minimum="0"/>
          </StackPanel>
          <StackPanel Grid.Column="1" Margin="5,0,0,0">
            <TextBlock Text="Unit Cost:" FontSize="12"/>
            <NumericUpDown Value="{Binding CostToAdd}" FormatString="0.00" Minimum="0"/>
          </StackPanel>
        </Grid>
        <Button Content="Add Item" Command="{Binding AddItemCommand}" Background="#3B82F6" Foreground="White" HorizontalAlignment="Right"/>
      </StackPanel>

      <!-- Items List -->
      <DataGrid Grid.Row="1" Grid.ColumnSpan="2" ItemsSource="{Binding Items}" AutoGenerateColumns="False" Margin="0,20,0,0">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Product ID" Binding="{Binding ProductId}" Width="*"/>
          <DataGridTextColumn Header="Qty" Binding="{Binding QuantityOrdered}" Width="100"/>
          <DataGridTextColumn Header="Cost" Binding="{Binding UnitCost, StringFormat={}{0:C}}" Width="100"/>
          <DataGridTemplateColumn Header="" Width="80">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <Button Content="Remove" Foreground="Red" Background="Transparent" 
                        Command="{Binding #RootGrid.((vm:AddPurchaseOrderViewModel)DataContext).RemoveItemCommand}" 
                        CommandParameter="{Binding}"/>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
        </DataGrid.Columns>
      </DataGrid>
    </Grid>
  </DockPanel>
</UserControl>
