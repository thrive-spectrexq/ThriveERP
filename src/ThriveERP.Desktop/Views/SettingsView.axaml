<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ThriveERP.Desktop.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ThriveERP.Desktop.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">
  <StackPanel Margin="20" Spacing="20">
    <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="Bold"/>

    <Border Padding="20" Background="{DynamicResource SystemRegionBrush}" BorderBrush="Gray" BorderThickness="1" CornerRadius="8">
      <StackPanel Spacing="15">
        <TextBlock Text="Application Settings" FontWeight="SemiBold" FontSize="18"/>
        
        <CheckBox Content="Enable Dark Mode" IsChecked="{Binding IsDarkMode}" />
        <CheckBox Content="Enable Offline Mode" IsChecked="True" />
        
        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" Margin="0,10,0,0">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Company Name:" VerticalAlignment="Center" Margin="0,0,10,0"/>
          <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding CompanyName}" Margin="0,0,0,10"/>
          
          <TextBlock Grid.Row="1" Grid.Column="0" Text="Currency Symbol:" VerticalAlignment="Center" Margin="0,0,10,0"/>
          <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CurrencySymbol}" />
        </Grid>
        
        <Button Content="Save Settings" Command="{Binding SaveSettingsCommand}" Background="#107C10" Foreground="White" HorizontalAlignment="Right" Margin="0,10,0,0"/>
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
