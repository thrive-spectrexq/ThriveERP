<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ThriveERP.Desktop.ViewModels"
             x:Class="ThriveERP.Desktop.Views.AddExpenseView"
             x:DataType="vm:AddExpenseViewModel"
             Background="{DynamicResource SurfaceBackground}">
    <Border Background="{DynamicResource CardBackground}" CornerRadius="8" Padding="30" Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="400">
        <StackPanel Spacing="15">
            <TextBlock Text="Add New Expense" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
            
            <TextBlock Text="Expense Account" />
            <ComboBox ItemsSource="{Binding AvailableAccounts}" SelectedItem="{Binding SelectedAccount}" HorizontalAlignment="Stretch">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Text="Category" />
            <TextBox Text="{Binding Category}" PlaceholderText="e.g. Office Supplies" />

            <TextBlock Text="Amount" />
            <NumericUpDown Value="{Binding Amount}" Minimum="0" FormatString="C" />

            <TextBlock Text="Date" />
            <DatePicker SelectedDate="{Binding ExpenseDate}" HorizontalAlignment="Stretch" />

            <TextBlock Text="Description" />
            <TextBox Text="{Binding Description}" AcceptsReturn="True" Height="60" />

            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Cancel" Command="{Binding CancelCommand}" />
                <Button Content="Save Expense" Command="{Binding SaveCommand}" Classes="accent" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
