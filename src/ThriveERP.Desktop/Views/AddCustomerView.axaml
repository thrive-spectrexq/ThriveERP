<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ThriveERP.Desktop.ViewModels"
             x:Class="ThriveERP.Desktop.Views.AddCustomerView"
             x:DataType="vm:AddCustomerViewModel">
  <Border Padding="20" Background="{DynamicResource SystemRegionBrush}" 
          BorderBrush="Gray" BorderThickness="1" CornerRadius="8"
          HorizontalAlignment="Center" VerticalAlignment="Center" Width="450">
    <StackPanel Spacing="10">
      <TextBlock Text="Add New Customer" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
      
      <TextBox PlaceholderText="Name *" Text="{Binding Name}" />
      
      <Grid ColumnDefinitions="*,*">
        <TextBox Grid.Column="0" PlaceholderText="Phone" Text="{Binding Phone}" Margin="0,0,5,0"/>
        <TextBox Grid.Column="1" PlaceholderText="Email" Text="{Binding Email}" Margin="5,0,0,0"/>
      </Grid>
      
      <TextBox PlaceholderText="Address" Text="{Binding Address}" AcceptsReturn="True" Height="60"/>
      <TextBox PlaceholderText="Credit Limit" Text="{Binding CreditLimit}" />

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,20,0,0">
        <Button Content="Cancel" Command="{Binding CancelCommand}" />
        <Button Content="Save" Command="{Binding SaveCommand}" Background="#0078D7" Foreground="White" />
      </StackPanel>
    </StackPanel>
  </Border>
</UserControl>
