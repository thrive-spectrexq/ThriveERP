<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ThriveERP.Desktop.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="ThriveERP.Desktop.Views.SalesView"
             x:Name="SalesRoot"
             x:DataType="vm:SalesViewModel">
  <Panel>
    <TabControl Background="Transparent" Padding="0">
      
      <!-- TAB 1: POS TERMINAL -->
      <TabItem Header="POS Terminal">
        <Grid ColumnDefinitions="*, 400" Background="Transparent">
          
          <!-- POS Left Side: Products Grid -->
          <DockPanel Grid.Column="0" Margin="15">
            <!-- Search & Filter -->
            <Border DockPanel.Dock="Top" Background="Transparent" CornerRadius="8" Padding="15" BoxShadow="0 2 10 0 #05000000" Margin="0,0,0,15">
              <Grid ColumnDefinitions="*, Auto, Auto">
                <TextBox Grid.Column="0" PlaceholderText="Search for products by name, SKU, or barcode..." Text="{Binding SearchQuery}" FontSize="16" Padding="10"/>
                <Button Grid.Column="1" Content="Search &amp; Add" Command="{Binding SearchAndAddCommand}" Background="#0284C7" Foreground="White" Padding="20,10" Margin="10,0,0,0" CornerRadius="4" FontWeight="SemiBold"/>
                <Button Grid.Column="2" Content="Scan Barcode" Background="#107C10" Foreground="White" Padding="20,10" Margin="10,0,0,0" CornerRadius="4" FontWeight="SemiBold"/>
              </Grid>
            </Border>

            <!-- Product Cards -->
            <ScrollViewer>
              <ItemsControl ItemsSource="{Binding PosProducts}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Stretch" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Button Command="{Binding $parent[UserControl].((vm:SalesViewModel)DataContext).AddToCartCommand}" CommandParameter="{Binding}" Background="Transparent" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="1" CornerRadius="8" Margin="5" Padding="0" Width="160" Height="140" Cursor="Hand">
                      <Grid RowDefinitions="*, Auto">
                        <Border Grid.Row="0" Background="Transparent" CornerRadius="8,8,0,0">
                          <!-- Image placeholder -->
                          <TextBlock Text="📦" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#CBD5E1"/>
                        </Border>
                        <StackPanel Grid.Row="1" Margin="10" Background="Transparent">
                          <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" TextTrimming="CharacterEllipsis"/>
                          <TextBlock Text="{Binding SellingPrice, StringFormat={}{0:C}}" FontSize="14" Foreground="#0284C7" FontWeight="Bold" Margin="0,4,0,0"/>
                        </StackPanel>
                      </Grid>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </DockPanel>

          <!-- POS Right Side: Cart / Checkout -->
          <Border Grid.Column="1" Background="Transparent" BorderThickness="1,0,0,0" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BoxShadow="-5 0 15 0 #05000000">
            <DockPanel>
              <!-- Cart Header -->
              <Border DockPanel.Dock="Top" Background="Transparent" Padding="20" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
                <Grid ColumnDefinitions="*, Auto">
                  <TextBlock Grid.Column="0" Text="Current Order" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                  <Button Grid.Column="1" Content="Clear" Command="{Binding ClearCartCommand}" Background="Transparent" Foreground="#EF4444" FontWeight="SemiBold"/>
                </Grid>
              </Border>

              <!-- Totals & Checkout (Bottom) -->
              <Border DockPanel.Dock="Bottom" Background="Transparent" Padding="20" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
                <StackPanel Spacing="10">
                  <Grid ColumnDefinitions="*, Auto">
                    <TextBlock Grid.Column="0" Text="Subtotal:" FontSize="16" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Subtotal, StringFormat={}{0:C}}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                  </Grid>
                  <Grid ColumnDefinitions="*, Auto">
                    <TextBlock Grid.Column="0" Text="Tax (10%):" FontSize="16" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Tax, StringFormat={}{0:C}}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                  </Grid>
                  <Border Height="1" Background="#E2E8F0" Margin="0,5"/>
                  <Grid ColumnDefinitions="*, Auto">
                    <TextBlock Grid.Column="0" Text="Total:" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                    <TextBlock Grid.Column="1" Text="{Binding GrandTotal, StringFormat={}{0:C}}" FontSize="24" FontWeight="Bold" Foreground="#0284C7"/>
                  </Grid>
                  
                  <Button Content="PAY NOW" Command="{Binding CheckoutCommand}" Background="#0EA5E9" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="20" Margin="0,15,0,0" CornerRadius="8"/>
                </StackPanel>
              </Border>

              <!-- Cart Items List -->
              <ListBox ItemsSource="{Binding CartItems}" Background="Transparent" BorderThickness="0">
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <Grid ColumnDefinitions="*, Auto" Margin="10,5" Background="Transparent">
                      <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="15" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                        <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,5,0,0">
                          <TextBlock Text="{Binding Quantity}" FontSize="14" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                          <TextBlock Text="x" FontSize="14" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                          <TextBlock Text="{Binding UnitPrice, StringFormat={}{0:C}}" FontSize="14" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        </StackPanel>
                      </StackPanel>
                      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="15">
                        <TextBlock Text="{Binding LineTotal, StringFormat={}{0:C}}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" VerticalAlignment="Center"/>
                        <Button Content="✕" Command="{Binding $parent[UserControl].((vm:SalesViewModel)DataContext).RemoveFromCartCommand}" CommandParameter="{Binding}" Background="Transparent" Foreground="#EF4444" FontSize="16" Padding="5" VerticalAlignment="Center"/>
                      </StackPanel>
                    </Grid>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>

            </DockPanel>
          </Border>
        </Grid>
      </TabItem>

      <!-- TAB 2: SALES ORDERS HISTORY -->
      <TabItem Header="Sales Orders (History)">
        <DockPanel Background="Transparent">
          <!-- Toolbar -->
          <Border DockPanel.Dock="Top" Background="Transparent" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" Padding="15,10">
            <Grid ColumnDefinitions="Auto, *, Auto">
              <TextBlock Grid.Column="0" Text="Order History" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" VerticalAlignment="Center"/>
              <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10">
                <TextBox PlaceholderText="Search orders..." Text="{Binding SalesOrderSearchQuery}" Width="250" VerticalAlignment="Center" CornerRadius="4"/>
                <Button Content="Refresh" Command="{Binding LoadSalesOrdersCommand}" Background="Transparent" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" Padding="15,8" CornerRadius="4"/>
              </StackPanel>
            </Grid>
          </Border>

          <!-- Main Split View -->
          <Grid ColumnDefinitions="*, 4, 550">
            
            <!-- Left: DataGrid -->
            <Border Grid.Column="0" Background="Transparent" Margin="10" CornerRadius="4" BorderThickness="1" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BoxShadow="0 2 10 0 #10000000">
              <DataGrid ItemsSource="{Binding FilteredSalesOrders}" 
                        SelectedItem="{Binding SelectedSalesOrder}"
                        AutoGenerateColumns="False" 
                        IsReadOnly="True"
                        GridLinesVisibility="Horizontal"
                        BorderThickness="0"
                        RowBackground="Transparent">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Order #" Binding="{Binding OrderNumber}" Width="120"/>
                  <DataGridTextColumn Header="Date" Binding="{Binding OrderDate, StringFormat='{}{0:d}'}" Width="120" />
                  <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120" />
                  <DataGridTextColumn Header="Total" Binding="{Binding GrandTotal, StringFormat={}{0:C}}" Width="*" />
                </DataGrid.Columns>
              </DataGrid>
            </Border>

            <!-- Grid Splitter -->
            <GridSplitter Grid.Column="1" Background="Transparent" ResizeDirection="Columns"/>

            <!-- Right: Detail Panel -->
            <Border Grid.Column="2" Background="Transparent" Margin="10,10,10,10" CornerRadius="4" BorderThickness="1" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BoxShadow="0 2 10 0 #10000000">
              <Panel>
                <!-- Empty State -->
                <TextBlock IsVisible="{Binding SelectedSalesOrder, Converter={x:Static ObjectConverters.IsNull}}"
                           Text="Select an order to view details"
                           HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#94A3B8" FontSize="14"/>
                
                <!-- Detail Content -->
                <Grid RowDefinitions="Auto, *" IsVisible="{Binding SelectedSalesOrder, Converter={x:Static ObjectConverters.IsNotNull}}">
                  
                  <!-- Header -->
                  <Border Grid.Row="0" Background="Transparent" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" Padding="15">
                    <Grid ColumnDefinitions="*, Auto">
                      <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding SelectedSalesOrder.OrderNumber}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,5,0,0">
                          <Border Background="#DBEAFE" CornerRadius="12" Padding="8,2">
                            <TextBlock Text="{Binding SelectedSalesOrder.Status}" FontSize="12" FontWeight="SemiBold" Foreground="#1D4ED8"/>
                          </Border>
                          <TextBlock Text="{Binding SelectedSalesOrder.OrderDate, StringFormat='{}{0:g}'}" FontSize="14" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                      </StackPanel>
                      
                      <!-- Action Buttons -->
                      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <Button Content="📄 Export PDF" Command="{Binding ExportInvoiceCommand}" Background="#10B981" Foreground="White" FontWeight="SemiBold" Padding="15,8" CornerRadius="4"/>
                      </StackPanel>
                    </Grid>
                  </Border>

                  <!-- Tabs -->
                  <TabControl Grid.Row="1" Margin="5">
                    <!-- Tab 1: Line Items -->
                    <TabItem Header="Items">
                      <Grid>
                        <DataGrid ItemsSource="{Binding SelectedOrderItems}" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal" BorderThickness="0" RowBackground="Transparent">
                          <DataGrid.Columns>
                            <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="*" />
                            <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="50" />
                            <DataGridTextColumn Header="Price" Binding="{Binding UnitPrice, StringFormat={}{0:C}}" Width="80" />
                            <DataGridTextColumn Header="Total" Binding="{Binding LineTotal, StringFormat={}{0:C}}" Width="80" />
                            <DataGridTemplateColumn Header="Action" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Return" Command="{Binding $parent[UserControl].((vm:SalesViewModel)DataContext).InitiateReturnCommand}" CommandParameter="{Binding}" Classes="accent" FontSize="12" Padding="10,5" Margin="5"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                          </DataGrid.Columns>
                        </DataGrid>
                      </Grid>
                    </TabItem>
                    
                    <!-- Tab 2: Invoice & Payments -->
                    <TabItem Header="Invoice/Payment">
                      <Grid>
                        <TextBlock Text="Invoice and payment history will appear here" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#94A3B8" TextWrapping="Wrap" TextAlignment="Center" Margin="20"/>
                      </Grid>
                    </TabItem>
                  </TabControl>
                </Grid>
              </Panel>
            </Border>
          </Grid>
        </DockPanel>
      </TabItem>
    </TabControl>


    <!-- Overlay for Add/Edit (If needed in future) -->
    <Border Background="#80000000" IsVisible="{Binding CurrentOverlay, Converter={x:Static ObjectConverters.IsNotNull}}">
      <ContentControl Content="{Binding CurrentOverlay}" />
    </Border>

    <!-- Payment Overlay -->
    <Grid Background="#80000000" IsVisible="{Binding ShowPaymentOverlay}" ZIndex="100">
        <Border Background="{DynamicResource SystemRegionBrush}" 
                BorderBrush="Gray" BorderThickness="1" CornerRadius="8"
                HorizontalAlignment="Center" VerticalAlignment="Center" 
                Width="400" Padding="30">
            <StackPanel Spacing="15">
                <TextBlock Text="Complete Payment" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                
                <TextBlock Text="{Binding GrandTotal, StringFormat='Total Due: {0:C}'}" FontSize="24" FontWeight="Bold" Foreground="#107C10" HorizontalAlignment="Center"/>

                <StackPanel Spacing="5">
                    <TextBlock Text="Payment Method:" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding AvailablePaymentMethods}" 
                              SelectedItem="{Binding SelectedPaymentMethod}" 
                              HorizontalAlignment="Stretch"/>
                </StackPanel>

                <StackPanel Spacing="5" IsVisible="{Binding SelectedPaymentMethod, Converter={x:Static ObjectConverters.Equal}, ConverterParameter='Cash'}">
                    <TextBlock Text="Amount Tendered:" FontWeight="SemiBold"/>
                    <NumericUpDown Value="{Binding AmountTendered}" Minimum="0" Increment="1" FormatString="C"/>
                </StackPanel>

                <StackPanel Spacing="5" IsVisible="{Binding SelectedPaymentMethod, Converter={x:Static ObjectConverters.Equal}, ConverterParameter='Cash'}">
                    <TextBlock Text="Change / Balance:" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding ChangeAmount, StringFormat={}{0:C}}" FontSize="20" FontWeight="Bold" Foreground="#EF4444"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,20,0,0">
                    <Button Content="Cancel" Command="{Binding CancelPaymentCommand}"/>
                    <Button Content="Confirm &amp; Print Receipt" Command="{Binding ConfirmPaymentCommand}" Background="#0D9488" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>

    <!-- Return Overlay -->
    <Grid Background="#80000000" IsVisible="{Binding ShowReturnOverlay}" ZIndex="100">
      <Border Background="{DynamicResource CardBackground}" CornerRadius="12" Padding="30" Width="400" HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel Spacing="15">
          <TextBlock Text="Process Return" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,10"/>
          
          <TextBlock Text="{Binding SelectedSaleItemForReturn.ProductName, StringFormat='Product: {0}'}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
          <TextBlock Text="{Binding SelectedSaleItemForReturn.Quantity, StringFormat='Max Qty available to return: {0}'}" FontSize="12" Foreground="{DynamicResource TextSecondary}" />
          
          <TextBlock Text="Quantity to Return:" FontSize="14" Foreground="{DynamicResource TextSecondary}" Margin="0,10,0,0"/>
          <NumericUpDown Value="{Binding ReturnQuantity}" Minimum="1" Maximum="{Binding SelectedSaleItemForReturn.Quantity}" Increment="1" FontSize="16" />
          
          <TextBlock Text="Reason:" FontSize="14" Foreground="{DynamicResource TextSecondary}" Margin="0,10,0,0"/>
          <TextBox Text="{Binding ReturnReason}" Watermark="e.g. Defective, Customer changed mind..." FontSize="14" Height="80" AcceptsReturn="True" TextWrapping="Wrap" />
          
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,20,0,0">
            <Button Content="Cancel" Command="{Binding CancelReturnCommand}" Classes="outline" />
            <Button Content="Confirm Return" Command="{Binding ProcessReturnCommand}" Classes="accent" />
          </StackPanel>
        </StackPanel>
      </Border>
    </Grid>
  </Panel>
</UserControl>
