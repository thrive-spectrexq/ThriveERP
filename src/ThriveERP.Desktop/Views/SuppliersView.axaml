<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ThriveERP.Desktop.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
             x:Class="ThriveERP.Desktop.Views.SuppliersView"
             x:DataType="vm:SuppliersViewModel">
  <Panel>
    <DockPanel Background="Transparent">
      <!-- Toolbar -->
      <Border DockPanel.Dock="Top" Background="Transparent" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" Padding="15,10">
        <Grid ColumnDefinitions="Auto, *, Auto">
          <TextBlock Grid.Column="0" Text="Suppliers" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" VerticalAlignment="Center"/>
          
          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10">
            <TextBox PlaceholderText="Search suppliers..." Text="{Binding SearchQuery}" Width="250" VerticalAlignment="Center" CornerRadius="4"/>
            <Button Content="Refresh" Command="{Binding LoadSuppliersCommand}" Background="Transparent" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" Padding="15,8" CornerRadius="4"/>
            <Button Content="Add New Supplier" Command="{Binding ShowAddSupplierCommand}" Background="#0284C7" Foreground="White" Padding="15,8" CornerRadius="4" FontWeight="SemiBold"/>
          </StackPanel>
        </Grid>
      </Border>

      <!-- Main Split View -->
      <Grid ColumnDefinitions="*, 4, 350">
        
        <!-- Left: DataGrid -->
        <Border Grid.Column="0" Background="Transparent" Margin="10" CornerRadius="4" BorderThickness="1" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BoxShadow="0 2 10 0 #10000000">
          <DataGrid ItemsSource="{Binding FilteredSuppliers}" 
                    SelectedItem="{Binding SelectedSupplier}"
                    AutoGenerateColumns="False" 
                    IsReadOnly="True"
                    GridLinesVisibility="Horizontal"
                    BorderThickness="0"
                    RowBackground="Transparent">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
              <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="150" />
              <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150" />
              <DataGridTextColumn Header="Balance" Binding="{Binding CurrentBalance, StringFormat={}{0:C}}" Width="120" />
            </DataGrid.Columns>
          </DataGrid>
        </Border>

        <!-- Grid Splitter -->
        <GridSplitter Grid.Column="1" Background="Transparent" ResizeDirection="Columns"/>

        <!-- Right: Detail Panel -->
        <Border Grid.Column="2" Background="Transparent" Margin="10,10,10,10" CornerRadius="4" BorderThickness="1" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BoxShadow="0 2 10 0 #10000000">
          <Panel>
            <!-- Empty State -->
            <TextBlock IsVisible="{Binding SelectedSupplier, Converter={x:Static ObjectConverters.IsNull}}"
                       Text="Select a supplier to view details"
                       HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#94A3B8" FontSize="14"/>
            
            <!-- Detail Content -->
            <Grid RowDefinitions="Auto, *" IsVisible="{Binding SelectedSupplier, Converter={x:Static ObjectConverters.IsNotNull}}">
              
              <!-- Header -->
              <Border Grid.Row="0" Background="Transparent" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" Padding="15">
                <StackPanel>
                  <TextBlock Text="{Binding SelectedSupplier.Name}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                  <TextBlock Text="{Binding SelectedSupplier.Email}" FontSize="14" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" Margin="0,5,0,0"/>
                </StackPanel>
              </Border>

              <!-- Tabs -->
              <TabControl Grid.Row="1" Margin="5">
                <!-- Tab 1: Info -->
                <TabItem Header="General Info">
                  <ScrollViewer>
                    <StackPanel Spacing="15" Margin="10">
                      <StackPanel>
                        <TextBlock Text="Phone" FontWeight="SemiBold" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" FontSize="12"/>
                        <TextBlock Text="{Binding SelectedSupplier.Phone}" FontSize="14" Margin="0,2,0,0"/>
                      </StackPanel>
                      <StackPanel>
                        <TextBlock Text="Address" FontWeight="SemiBold" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" FontSize="12"/>
                        <TextBlock Text="{Binding SelectedSupplier.Address}" FontSize="14" Margin="0,2,0,0" TextWrapping="Wrap"/>
                      </StackPanel>
                      <StackPanel>
                        <TextBlock Text="Current Balance" FontWeight="SemiBold" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" FontSize="12"/>
                        <TextBlock Text="{Binding SelectedSupplier.CurrentBalance, StringFormat={}{0:C}}" FontSize="14" Margin="0,2,0,0" FontWeight="Bold" Foreground="#EF4444"/>
                      </StackPanel>
                      
                      <Separator Background="#E2E8F0" Margin="0,10"/>
                      
                      <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                        <Button Content="Edit" Command="{Binding EditSupplierCommand}" CommandParameter="{Binding SelectedSupplier}" Background="#3B82F6" Foreground="White" Padding="15,8" CornerRadius="4"/>
                        <Button Content="Delete" Command="{Binding DeleteSupplierCommand}" CommandParameter="{Binding SelectedSupplier}" Background="#EF4444" Foreground="White" Padding="15,8" CornerRadius="4"/>
                      </StackPanel>
                    </StackPanel>
                  </ScrollViewer>
                </TabItem>
                
                <!-- Tab 2: Orders -->
                <TabItem Header="Purchase Orders">
                  <Grid>
                    <TextBlock Text="Recent purchase orders will appear here" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#94A3B8"/>
                  </Grid>
                </TabItem>
              </TabControl>

            </Grid>
          </Panel>
        </Border>
      </Grid>
    </DockPanel>

    <!-- Overlay for Add/Edit -->
    <Border Background="#80000000" IsVisible="{Binding CurrentOverlay, Converter={x:Static ObjectConverters.IsNotNull}}">
      <ContentControl Content="{Binding CurrentOverlay}" />
    </Border>
  </Panel>
</UserControl>
