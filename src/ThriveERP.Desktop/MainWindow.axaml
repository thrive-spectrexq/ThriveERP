<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ThriveERP.Desktop.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
        x:Class="ThriveERP.Desktop.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="ThriveERP - Modern Enterprise Management"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource SystemRegionBrush}">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- TOP NAVBAR / HEADER -->
        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Height="60">
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="20,0">
                <!-- Brand / Logo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                    <TextBlock Text="◆" FontSize="20" Foreground="#2563EB" VerticalAlignment="Center"/>
                    <TextBlock Text="ThriveERP" FontSize="20" FontWeight="ExtraBold" Foreground="#1E293B" VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- Global Search -->
                <TextBox Grid.Column="1" Width="400" HorizontalAlignment="Center" VerticalAlignment="Center" 
                         Watermark="Search anything (Ctrl+K)..." CornerRadius="8" Padding="10,6"
                         Background="#F1F5F9" BorderThickness="0"/>
                         
                <!-- User Profile & Notifications -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="20">
                    <TextBlock Text="🔔 Notifications (3)" Foreground="#64748B" VerticalAlignment="Center"/>
                    <Border Background="#E2E8F0" CornerRadius="20" Padding="10,5">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="👤" VerticalAlignment="Center"/>
                            <TextBlock Text="Admin User" FontWeight="SemiBold" Foreground="#0F172A" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT AREA WITH SIDEBAR -->
        <SplitView Grid.Row="1" IsPaneOpen="True" DisplayMode="Inline" OpenPaneLength="250" PaneBackground="#F8FAFC">
            <SplitView.Pane>
                <Grid RowDefinitions="*, Auto" Margin="0,10,0,0">
                    <ScrollViewer Grid.Row="0">
                        <ListBox ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedListItem}" 
                                 Background="Transparent" Foreground="#334155" SelectionMode="Single"
                                 BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="15,12" CornerRadius="8" Margin="10,2">
                                        <StackPanel Orientation="Horizontal" Spacing="15">
                                            <TextBlock Text="◆" FontSize="12" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Label}" FontSize="15" VerticalAlignment="Center" FontWeight="Medium" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </Grid>
            </SplitView.Pane>

            <SplitView.Content>
                <!-- Inner Page Shadow/Border -->
                <Border Background="#FFFFFF" Margin="1" BoxShadow="inset 0 0 5 0 #10000000">
                    <TransitioningContentControl Content="{Binding CurrentPage}" />
                </Border>
            </SplitView.Content>
        </SplitView>

        <!-- FOOTER / BOTTOM STATUS BAR -->
        <Border Grid.Row="2" Background="#1E293B" Height="30" Padding="10,0">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="15" VerticalAlignment="Center">
                    <TextBlock Text="🟢 DB Connected" Foreground="#4ADE80" FontSize="11" FontWeight="Medium"/>
                    <TextBlock Text="SQLite (Local)" Foreground="#94A3B8" FontSize="11"/>
                </StackPanel>
                
                <TextBlock Grid.Column="2" Text="ThriveERP v1.0.0-preview" Foreground="#94A3B8" FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
